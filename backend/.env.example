# Copy this to .env and fill in values. Never commit .env.

# LLM mode — default is real Gemini. Flip to 1 to run fully offline (mock agent + mock embeddings).
USE_MOCK_LLM=0

# Required when USE_MOCK_LLM=0. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini models
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# CORS: frontend dev server
FRONTEND_ORIGIN=http://localhost:5173
